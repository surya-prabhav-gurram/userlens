# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=your_key_here

# Database (auto-configured in Docker Compose)
DATABASE_URL=postgresql://userlens:userlens@localhost:5432/userlens

# MLflow (auto-configured in Docker Compose)
MLFLOW_TRACKING_URI=http://localhost:5000

# Model paths (optional — defaults to experiments/ subdirs)
PRETRAIN_CKPT=experiments/pretrain/best_bert4rec.pt
RETRIEVAL_CKPT=experiments/retrieval/best_two_tower.pt
RANKING_CKPT=experiments/ranking/best_ranker.pt

# Device: cpu or cuda
DEVICE=cpu
